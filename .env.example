# App
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_GLOBAL_PREFIX=api
APP_CORS_ORIGIN=*
APP_BODY_LIMIT=100kb
APP_ENABLE_SWAGGER=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=short_url
DB_USER=postgres
DB_PASSWORD=Pg!Strong123
DB_SSL=false
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Redis!Strong123
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=10000

# Observability / logging
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_REDACT_SENSITIVE=true
