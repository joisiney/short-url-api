# Ambiente de teste - isolado de dev/prod (ADR 00-10)
NODE_ENV=test
APP_PORT=3001
APP_HOST=localhost
APP_GLOBAL_PREFIX=api
APP_CORS_ORIGIN=*
APP_BODY_LIMIT=100kb
APP_ENABLE_SWAGGER=false
APP_HTTP_TIMEOUT_MS=5000

# Database - banco de teste separado
DB_HOST=localhost
DB_PORT=5432
DB_NAME=short_url_test
DB_USER=postgres
DB_PASSWORD=Pg!Strong123
DB_SSL=false
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000

# Redis - isolado para testes
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Redis!Strong123
REDIS_DB=1
REDIS_TLS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=5000
CACHE_TTL_SECONDS=60

# Logger
LOG_LEVEL=error
LOG_PRETTY=false
LOG_REDACT_SENSITIVE=true
