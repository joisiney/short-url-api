# Ambiente de teste - isolado de dev/prod (ADR 00-10)
NODE_ENV=test
APP_PORT=3001
APP_HOST=localhost
APP_GLOBAL_PREFIX=api
APP_CORS_ORIGIN=*
APP_BODY_LIMIT=100kb
APP_ENABLE_SWAGGER=false
APP_HTTP_TIMEOUT_MS=5000

# Database - banco de teste separado
PG_HOST=localhost
PG_PORT=5432
PG_NAME=short_url_test
PG_USER=postgres
PG_PWD=Pg!Strong123
PG_SSL=false
PG_POOL_MIN=1
PG_POOL_MAX=5
PG_IDLE_TIMEOUT_MS=10000
PG_CONNECTION_TIMEOUT_MS=5000

# Redis - isolado para testes
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=Redis!Strong123
REDIS_DB=1
REDIS_TLS_ENABLED=false
REDIS_CONNECT_TIMEOUT_MS=5000
CACHE_TTL_SECONDS=60

# Short code (teste determinístico; nao usar em producao)
SHORT_CODE_FEISTEL_SECRET=test_short_code_feistel_secret_32chars_min

# Logger
LOG_LEVEL=error
LOG_PRETTY=false
LOG_REDACT_SENSITIVE=true
